<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#1976D2">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Sparziele"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Trage dein Ziel und deinen aktuellen Stand ein."
        android:textColor="#CCFFFFFF"
        android:textSize="14sp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Eingabekarte -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_inputs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#155FA0"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zielbetrag (€)"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"/>

            <EditText
                android:id="@+id/et_goal"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@android:color/transparent"
                android:hint="z. B. 4000"
                android:inputType="numberDecimal"
                android:padding="10dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#22FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bereits gespart (€)"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"/>

            <EditText
                android:id="@+id/et_saved"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@android:color/transparent"
                android:hint="z. B. 3000"
                android:inputType="numberDecimal"
                android:padding="10dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Donut-Karte -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_donut"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#155FA0"
        app:layout_constraintTop_toBottomOf="@id/card_inputs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <!-- Donut: responsive, immer rund -->
            <ProgressBar
                android:id="@+id/progress_ring"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:indeterminate="false"
                android:max="100"
                android:rotation="-90"
                android:progress="75"
                android:progressDrawable="@drawable/progress_ring"
                android:layout_margin="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintDimensionRatio="1:1" />

            <!-- Text in der Mitte -->
            <LinearLayout
                android:id="@+id/center_text_block"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="@id/progress_ring"
                app:layout_constraintBottom_toBottomOf="@id/progress_ring"
                app:layout_constraintStart_toStartOf="@id/progress_ring"
                app:layout_constraintEnd_toEndOf="@id/progress_ring">

                <TextView
                    android:id="@+id/tv_center_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Noch bis zum Ziel"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_center_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.000,00 €"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tv_center_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="75%"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>